rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers (Care Royal web app; new plural collections) ----
    function signedIn() { return request.auth != null; }
    function myDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function myTenant() { return myDoc().tenantId; }
    function myRole() { return myDoc().role; }
    // Agency-side staff who operate the console: Owner, coordinator, and Manager.
    // (Manager abilities are further gated per-manager in the app.)
    function isAgency() { return signedIn() && (myRole() == 'agency_admin' || myRole() == 'agency_coord' || myRole() == 'manager'); }
    // The agency Owner only — manages the team (approve/permission managers & staff).
    function isOwner() { return signedIn() && myRole() == 'agency_admin'; }
    // Care Royal platform super-admin, recognized by login email (no tenant/users doc).
    function isSuper() { return signedIn() && request.auth.token.email == 'info@thecareroyal.com'; }
    // resource (existing doc) / request.resource (incoming) belong to my tenant
    function sameTenantR() { return signedIn() && resource.data.tenantId == myTenant(); }
    function sameTenantW() { return signedIn() && request.resource.data.tenantId == myTenant(); }

    // ---- public pre-launch waitlist ----
    match /waitlist/{id} {
      allow create: if true;            // anyone can join
      allow read, update, delete: if false;  // exported by owner out-of-band
    }

    // ---- public quote requests: a prospective client fills a form (no account)
    // and it lands in one agency's pipeline. Must carry a tenantId. The agency
    // reads/updates its own; nobody can read across tenants.
    match /quoteRequests/{id} {
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;
      allow read, update: if isAgency() && resource.data.tenantId == myTenant();
      allow delete: if false;
    }

    // ---- public caregiver applications (recruiting): same shape as quotes.
    match /caregiverApplications/{id} {
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;
      allow read, update: if isAgency() && resource.data.tenantId == myTenant();
      allow delete: if false;
    }

    // ---- reviews: publicly readable (agency microsite); anyone can leave one
    // (must carry a tenantId + 1-5 rating). Agency moderates its own.
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update, delete: if isAgency() && resource.data.tenantId == myTenant();
    }

    // ---- audit log: agency writes events for its own tenant; append-only.
    match /events/{id} {
      allow read: if isAgency() && resource.data.tenantId == myTenant();
      allow create: if signedIn() && request.resource.data.tenantId == myTenant();
      allow update, delete: if false;
    }

    // ---- public waitlist position counter (used by the marketing landing) ----
    match /counters/waitlist {
      allow read, write: if true;
    }
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // ---- tenants ----
    match /tenants/{tid} {
      // isSuper() first so the || short-circuits before myTenant() (which would
      // error for a super-admin, who has no users/{uid} doc). Super-admin also
      // needs list access for the approval console.
      allow read: if isSuper() || (signedIn() && myTenant() == tid);
      allow create: if signedIn();      // first admin creates their tenant (setup)
      allow update: if isSuper() || (isAgency() && myTenant() == tid);
      allow delete: if false;
    }

    // ---- join codes: public code -> tenant lookup so a family/caregiver can
    // join an existing agency at signup (before they have a profile). Contains
    // no sensitive data (tenantId + agency display name only).
    match /joinCodes/{code} {
      allow read: if true;
      allow create: if signedIn();      // agency admin mints its code at signup
      allow update, delete: if false;
    }

    // ---- user profiles (role + tenant live here) ----
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || (isAgency() && resource.data.tenantId == myTenant()));
      allow create: if signedIn() && request.auth.uid == uid;  // self profile at signup/setup
      // The Owner manages team members (status/role/permissions). A user may edit
      // their OWN profile but may NOT escalate their own role/status/permissions.
      allow update: if signedIn() && (
        (isOwner() && resource.data.tenantId == myTenant())
        || (request.auth.uid == uid
            && request.resource.data.role == resource.data.role
            && request.resource.data.get('status', 'active') == resource.data.get('status', 'active')
            && request.resource.data.get('permissions', {}) == resource.data.get('permissions', {}))
      );
      allow delete: if false;
    }

    // ---- agency-managed collections ----
    match /services/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /leads/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /invoices/{id} {
      allow read: if sameTenantR();
      allow create, update: if isAgency() && sameTenantW();
      allow delete: if false;
    }
    match /caregiverProfiles/{id} {
      allow read: if sameTenantR();
      allow create, update: if signedIn() && sameTenantW();
    }

    // ---- households & recipients (family-owned, tenant-isolated) ----
    match /households/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update: if signedIn() && sameTenantR();
    }
    match /recipients/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update, delete: if signedIn() && sameTenantR();
    }
    match /householdMembers/{id} {
      allow read: if sameTenantR();
      allow create, update, delete: if signedIn() && sameTenantW();
    }

    // ---- bookings: family requests, agency approves, caregiver completes ----
    // A caregiver may claim a booking into their own name (open-shift claim /
    // swap pickup); the paired shift rule below is the real gate on which
    // shifts can be taken (open only, never a colleague's scheduled shift).
    match /bookings/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW() && request.resource.data.status == 'requested';
      allow update: if sameTenantR() && (isAgency()
                    || resource.data.caregiverId == request.auth.uid
                    || request.resource.data.caregiverId == request.auth.uid);
    }

    // ---- shifts: agency creates; agency, assigned caregiver, or an open shift ----
    match /shifts/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update: if sameTenantR() && (isAgency() || resource.data.caregiverId == request.auth.uid || resource.data.status == 'open');
    }

    // ---- documents: agency issues, tenant member signs ----
    match /documents/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update: if sameTenantR();
    }

    // ---- messages: tenant members converse; agency (customer service) sees all.
    // (Intra-tenant thread privacy is tightened in the membership/assignment batch.)
    match /messages/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- ROADMAP FEATURES ----

    // Item 1: EVV billing — payers, prior authorizations, claims (agency only).
    match /payers/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /authorizations/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /claims/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create, update: if isAgency() && sameTenantW();
      allow delete: if false;
    }

    // Item 2: instant-pay payouts. Caregiver creates own; agency sees all; server completes.
    match /payouts/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW() && request.resource.data.caregiverId == request.auth.uid;
      allow update: if isAgency() && sameTenantR();
      allow delete: if false;
    }

    // Item 5: shift-swap marketplace. Any tenant member reads; caregivers post/claim their own.
    match /shiftSwaps/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update: if signedIn() && sameTenantR();
      allow delete: if false;
    }

    // Item 6: parent organizations (franchise / white-label).
    match /orgs/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // Item 8: family Care Journal. Tenant-scoped; caregivers/agency post, family reads.
    match /journal/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }

    // Item 9: anonymized cross-tenant benchmarks. Any signed-in agency reads; only
    // the scheduled Cloud Function (Admin SDK, bypasses rules) writes. No PII.
    match /benchmarks/{id} {
      allow read: if isAgency();
      allow write: if false;
    }
  }
}
