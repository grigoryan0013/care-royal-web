rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers (Care Royal web app; new plural collections) ----
    function signedIn() { return request.auth != null; }
    function myDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function myTenant() { return myDoc().tenantId; }
    function myRole() { return myDoc().role; }
    // Active = not awaiting approval. A self-joined manager is created "pending"
    // and must be activated by the owner before gaining any agency privilege —
    // without this check anyone could self-provision a pending manager of a victim
    // tenant (join codes are semi-public) and read/write all its data. Owners have
    // no status field, so a missing status defaults to active.
    function isActive() { return myDoc().get('status', 'active') == 'active'; }
    // Agency-side staff who operate the console: Owner, coordinator, and Manager.
    // (Manager abilities are further gated per-manager in the app.)
    function isAgency() { return signedIn() && isActive() && (myRole() == 'agency_admin' || myRole() == 'agency_coord' || myRole() == 'manager'); }
    // The agency Owner only — manages the team (approve/permission managers & staff).
    function isOwner() { return signedIn() && myRole() == 'agency_admin'; }
    // Care Royal platform super-admin, recognized by login email (no tenant/users doc).
    function isSuper() { return signedIn() && request.auth.token.email == 'info@thecareroyal.com'; }
    // resource (existing doc) / request.resource (incoming) belong to my tenant
    function sameTenantR() { return signedIn() && resource.data.tenantId == myTenant(); }
    function sameTenantW() { return signedIn() && request.resource.data.tenantId == myTenant(); }

    // Platform owner can READ any document (to view all agencies' portals).
    // Writes stay tenant-scoped, so this is a read-only oversight view.
    match /{document=**} {
      allow read: if isSuper();
    }

    // ---- public pre-launch waitlist ----
    match /waitlist/{id} {
      allow create: if true;            // anyone can join
      allow read, update, delete: if false;  // exported by owner out-of-band
    }

    // ---- public quote requests: a prospective client fills a form (no account)
    // and it lands in one agency's pipeline. Must carry a tenantId. The agency
    // reads/updates its own; nobody can read across tenants.
    match /quoteRequests/{id} {
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;
      allow read, update: if isAgency() && resource.data.tenantId == myTenant();
      allow delete: if false;
    }

    // ---- public caregiver applications (recruiting): same shape as quotes.
    match /caregiverApplications/{id} {
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0;
      allow read, update: if isAgency() && resource.data.tenantId == myTenant();
      allow delete: if false;
    }

    // ---- reviews: publicly readable (agency microsite); anyone can leave one
    // (must carry a tenantId + 1-5 rating). Agency moderates its own.
    match /reviews/{id} {
      allow read: if true;
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1 && request.resource.data.rating <= 5;
      allow update, delete: if isAgency() && resource.data.tenantId == myTenant();
    }

    // ---- audit log: agency writes events for its own tenant; append-only.
    match /events/{id} {
      allow read: if isAgency() && resource.data.tenantId == myTenant();
      allow create: if signedIn() && request.resource.data.tenantId == myTenant();
      allow update, delete: if false;
    }

    // ---- public waitlist position counter (used by the marketing landing) ----
    match /counters/waitlist {
      allow read, write: if true;
    }
    match /counters/{counterId} {
      allow read, write: if false;
    }

    // ---- tenants ----
    match /tenants/{tid} {
      // isSuper() first so the || short-circuits before myTenant() (which would
      // error for a super-admin, who has no users/{uid} doc). Super-admin also
      // needs list access for the approval console.
      allow read: if isSuper() || (signedIn() && myTenant() == tid);
      // New agencies are always waitlisted; only the super-admin can create an active one.
      allow create: if isSuper() || (signedIn() && request.resource.data.get('status', '') == 'pending');
      // Owner-only edits (not managers), and the payment/connection fields are
      // server-written (Cloud Functions, Admin SDK) — freeze them against any client
      // write so a member can't redirect family payments to their own Stripe account.
      allow update: if isSuper() || (isOwner() && myTenant() == tid
        && request.resource.data.get('stripeAccountId', '') == resource.data.get('stripeAccountId', '')
        && request.resource.data.get('qboConnected', false) == resource.data.get('qboConnected', false)
        && request.resource.data.get('payrollProvider', '') == resource.data.get('payrollProvider', '')
        && request.resource.data.get('status', '') == resource.data.get('status', ''));
      allow delete: if false;
    }

    // OAuth tokens (QuickBooks/Gusto) live here, written/read ONLY by Cloud
    // Functions via the Admin SDK (which bypasses rules). Never client-accessible.
    match /tenantSecrets/{tid} {
      allow read, write: if false;
    }

    // ---- join codes: public code -> tenant lookup so a family/caregiver can
    // join an existing agency at signup (before they have a profile). Contains
    // no sensitive data (tenantId + agency display name only).
    match /joinCodes/{code} {
      allow get: if true;                // single-code lookup at signup only…
      allow list: if false;              // …never enumerate every tenant's code
      allow create: if signedIn();       // agency admin mints its code at signup
      allow update, delete: if false;
    }

    // Public-safe copy of an agency's site/branding, rendered on the public
    // microsite/quote/apply pages (the tenants doc itself is NOT public-readable).
    // Contains only display fields (name, colors, logo, page content) — no PII.
    match /publicSites/{tid} {
      allow get: if true;
      allow list: if false;
      allow write: if isSuper() || (isOwner() && myTenant() == tid);
    }

    // ---- email -> account-type index (role only, no PII beyond the email key).
    // Public read so a blocked "email already in use" signup can tell the user
    // which account type already exists. Each user writes only their OWN entry
    // (the doc's email must equal their verified auth email).
    match /signupEmails/{key} {
      allow read: if true;
      allow create, update: if signedIn() && request.resource.data.email == request.auth.token.email;
      allow delete: if false;
    }

    // ---- user profiles (role + tenant live here) ----
    // SECURITY: the whole tenant-isolation model trusts users/{uid}.tenantId and
    // .role (myTenant()/myRole()). Therefore a self-created/self-edited profile
    // must NOT be able to forge either — otherwise any signed-in user could set
    // tenantId to a victim agency (discoverable via public reviews) and read all
    // its data. Creation is constrained to three legitimate shapes; self-edit
    // may never change tenantId, role, status, or permissions.
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || (isAgency() && resource.data.tenantId == myTenant()));

      allow create: if signedIn() && request.auth.uid == uid
        && request.resource.data.userId == uid
        && (
          // (a) Agency founder: the tenant must already exist and name me owner.
          (request.resource.data.role == 'agency_admin'
            && exists(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId))
            && get(/databases/$(database)/documents/tenants/$(request.resource.data.tenantId)).data.ownerUid == uid)
          // (b) Joining an existing agency by code (family/caregiver/manager),
          //     WAITLISTED: the joinCode must map to the claimed tenant.
          || (request.resource.data.role in ['family', 'caregiver', 'manager']
            && request.resource.data.get('status', '') == 'pending'
            && request.resource.data.tenantId != ''
            && exists(/databases/$(database)/documents/joinCodes/$(request.resource.data.get('joinCode', '__none__')))
            && get(/databases/$(database)/documents/joinCodes/$(request.resource.data.get('joinCode', '__none__'))).data.tenantId == request.resource.data.tenantId)
          // (c) Platform lead: family/caregiver with no agency yet, waitlisted.
          || (request.resource.data.role in ['family', 'caregiver']
            && request.resource.data.tenantId == ''
            && request.resource.data.get('status', '') == 'pending')
        );

      // The Owner manages team members (status/role/permissions). A user may edit
      // their OWN profile but may NOT change tenant/role/status/permissions.
      allow update: if signedIn() && (
        isSuper()                                                   // platform owner manages waitlisted people
        || (isOwner() && resource.data.tenantId == myTenant())
        || (request.auth.uid == uid
            && request.resource.data.tenantId == resource.data.tenantId
            && request.resource.data.role == resource.data.role
            && request.resource.data.get('status', 'active') == resource.data.get('status', 'active')
            && request.resource.data.get('permissions', {}) == resource.data.get('permissions', {}))
      );
      allow delete: if false;
    }

    // ---- agency-managed collections ----
    match /services/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /leads/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /invoices/{id} {
      allow read: if sameTenantR();
      allow create, update: if isAgency() && sameTenantW();
      allow delete: if false;
    }
    match /caregiverProfiles/{id} {
      allow read: if sameTenantR();
      // Agency may write anything. A caregiver may create/edit only their OWN
      // profile but may NOT set pay/vetting/payout fields — rate, bgCheckStatus,
      // bgCheckId, stripeAccountId, pin are agency/server-controlled (otherwise a
      // caregiver could inflate their own pay or self-clear a background check).
      allow create: if sameTenantW() && (
        isAgency() || (request.resource.data.userId == request.auth.uid
          && request.resource.data.get('rate', '') == ''
          && request.resource.data.get('bgCheckStatus', '') == ''
          && request.resource.data.get('bgCheckId', '') == ''
          && request.resource.data.get('stripeAccountId', '') == ''
          && request.resource.data.get('pin', '') == '')
      );
      allow update: if sameTenantW() && (
        isAgency() || (request.resource.data.userId == request.auth.uid
          && request.resource.data.get('rate', '') == resource.data.get('rate', '')
          && request.resource.data.get('bgCheckStatus', '') == resource.data.get('bgCheckStatus', '')
          && request.resource.data.get('bgCheckId', '') == resource.data.get('bgCheckId', '')
          && request.resource.data.get('stripeAccountId', '') == resource.data.get('stripeAccountId', '')
          && request.resource.data.get('pin', '') == resource.data.get('pin', ''))
      );
    }

    // ---- households & recipients (family-owned, tenant-isolated) ----
    match /households/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update: if signedIn() && sameTenantR();
    }
    match /recipients/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update, delete: if signedIn() && sameTenantR();
    }
    match /householdMembers/{id} {
      allow read: if sameTenantR();
      allow create, update, delete: if signedIn() && sameTenantW();
    }

    // ---- bookings: family requests, agency approves, caregiver completes ----
    // A caregiver may claim a booking into their own name (open-shift claim /
    // swap pickup); the paired shift rule below is the real gate on which
    // shifts can be taken (open only, never a colleague's scheduled shift).
    match /bookings/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW() && request.resource.data.status == 'requested';
      allow update: if sameTenantR() && (isAgency()
                    || resource.data.caregiverId == request.auth.uid
                    || request.resource.data.caregiverId == request.auth.uid);
    }

    // ---- shifts: agency creates; agency, assigned caregiver, or an open shift ----
    match /shifts/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update: if sameTenantR() && (isAgency() || resource.data.caregiverId == request.auth.uid || resource.data.status == 'open');
    }

    // ---- documents: agency issues, tenant member signs ----
    match /documents/{id} {
      allow read: if sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update: if sameTenantR();
    }

    // ---- messages: tenant members converse; agency (customer service) sees all.
    // (Intra-tenant thread privacy is tightened in the membership/assignment batch.)
    match /messages/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- ROADMAP FEATURES ----

    // Item 1: EVV billing — payers, prior authorizations, claims (agency only).
    match /payers/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /authorizations/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create: if isAgency() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }
    match /claims/{id} {
      allow read: if isAgency() && sameTenantR();
      allow create, update: if isAgency() && sameTenantW();
      allow delete: if false;
    }

    // Item 2: instant-pay payouts. Caregiver creates own; agency sees all; server completes.
    match /payouts/{id} {
      allow read: if sameTenantR();
      // Caregiver requests their own payout, always as "pending". The transfer amount
      // is recomputed and capped server-side (instantPayout) — the gross/net written
      // here are advisory only and get overwritten on completion.
      allow create: if signedIn() && sameTenantW()
        && request.resource.data.caregiverId == request.auth.uid
        && request.resource.data.get('status', '') == 'pending';
      allow update: if isAgency() && sameTenantR();
      allow delete: if false;
    }

    // Item 5: shift-swap marketplace. Any tenant member reads; caregivers post/claim their own.
    match /shiftSwaps/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update: if signedIn() && sameTenantR();
      allow delete: if false;
    }

    // Item 6: parent organizations (franchise / white-label). Readable only by
    // the org owner or a member of a tenant that belongs to this org — not by
    // every signed-in user (which would leak all orgs across tenants).
    match /orgs/{id} {
      allow read: if signedIn() && (
        resource.data.ownerUid == request.auth.uid
        || (myTenant() != '' && get(/databases/$(database)/documents/tenants/$(myTenant())).data.get('orgId', '') == id)
      );
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
    }

    // Item 8: family Care Journal. Tenant-scoped; caregivers/agency post, family reads.
    match /journal/{id} {
      allow read: if sameTenantR();
      allow create: if signedIn() && sameTenantW();
      allow update, delete: if isAgency() && sameTenantR();
    }

    // Item 9: anonymized cross-tenant benchmarks. Any signed-in agency reads; only
    // the scheduled Cloud Function (Admin SDK, bypasses rules) writes. No PII.
    match /benchmarks/{id} {
      allow read: if isAgency();
      allow write: if false;
    }
  }
}
